# MiniClaude 环境配置模板
# 用法：cp .env.example .env，然后按需修改

# ── Core Daemon ───────────────────────────────────────────────
MINI_HOST=127.0.0.1
MINI_PORT=7437

# ── Logging ───────────────────────────────────────────────────
MINI_LOG_LEVEL=INFO
# 留空则仅输出 stderr，不写文件
MINI_LOG_FILE=~/.mini/logs/core.log
# text（人工可读键值对）或 json（结构化，适合日志聚合）
MINI_LOG_FORMAT=text

# ── Config File ───────────────────────────────────────────────
# MINI_CONFIG=~/.mini/config.toml

# ── LLM（S1 阶段启用）────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# MINI_LLM_MODEL=claude-sonnet-4-6
# MINI_MAX_STEPS=20
